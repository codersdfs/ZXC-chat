{
  "name": "aichat-desktop",
  "version": "1.0.0",
  "description": "Electron desktop AI chat application using TypeScript with Ollama integration",
  "main": "dist/main/index.js",
  "type": "module",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.renderer.json && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "watch:main": "tsc -p tsconfig.main.json -w",
    "typecheck": "tsc -p tsconfig.renderer.json --noEmit && tsc -p tsconfig.main.json --noEmit",
    "lint": "eslint src --ext ts,tsx",
    "test": "vitest",
    "test:run": "vitest run",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"npm run watch:main\" \"wait-on tcp:5173 && set NODE_ENV=development && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:package": "npm run build && electron-builder --dir"
  },
  "devDependencies": {
    "@types/node": "^22.10.6",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^2.1.5",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "axios": "^1.3.4",
    "lucide-react": "^1.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^4.5.0"
  }
}
